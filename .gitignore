# Secrets — NEVER commit
.env
*.env
.env.*
!.env.example
# Public build config (backend URL, not a secret) — safe to commit so builds are reproducible
!frontend/.env.production

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Node / frontend
node_modules/
dist/

# Firebase Hosting local cache / deploy artifacts
.firebase/
firebase-debug.log

# Local working docs (kept out of the repo by request)
docs/

# Local DB / OS cruft (regenerable via scripts/seed_offline.py)
*.sqlite
*.sqlite3
*.db
.DS_Store
