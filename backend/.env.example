# Copy to .env and fill in to enable operator-wide live grading. NEVER commit .env.
# Any OpenAI-compatible provider works. Leave blank to grade deterministically offline.
# Examples:
#   OpenAI      LLM_BASE_URL=https://api.openai.com/v1        LLM_MODEL=gpt-4o-mini
#   Qwen        LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
#   OpenRouter  LLM_BASE_URL=https://openrouter.ai/api/v1     LLM_MODEL=anthropic/claude-3.5-sonnet
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional outbound webhooks — POST an event to your systems on every grade / remediate /
# override, so CI/Slack/SIEM can react (e.g. fail a deploy on RETIRE). Comma-separated
# URLs; leave blank to disable. If GM_WEBHOOK_SECRET is set, payloads are HMAC-SHA256
# signed in the X-GM-Signature header so the receiver can verify them.
GM_WEBHOOK_URLS=
GM_WEBHOOK_SECRET=
